# LLM API Keys
VN_TONGYI_API_KEY=
VN_DEEPSEEK_API_KEY=
VN_LLM_PROVIDER=tongyi

# Embedding
VN_EMBEDDING_API_KEY=

# Transcribe (Bjian)
VN_BJIAN_APP_ID=
VN_BJIAN_ACCESS_TOKEN=

# Whisper
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto

# Bilibili Cookie — 四种方式选一种：
# 方式一（本地开发推荐）：从浏览器读取，首次成功后自动缓存
#   VN_BILIBILI_COOKIE_SOURCE=browser
#   VN_BILIBILI_COOKIE_BROWSER=chrome    # chrome / firefox / edge / brave / opera
#
# 方式二（生产部署推荐）：用户在前端设置页粘贴 Cookie 字符串，不留明文文件
#   VN_BILIBILI_COOKIE_SOURCE=string
#
# 方式三：从 Netscape 格式 cookies.txt 读取（兼容旧方式）
#   VN_BILIBILI_COOKIE_SOURCE=file
#   VN_BILIBILI_COOKIE_FILE=data/cookies.txt
#
# 方式四：不使用 Cookie
#   VN_BILIBILI_COOKIE_SOURCE=none
