# LLM API Keys
VN_TONGYI_API_KEY=
VN_DEEPSEEK_API_KEY=
VN_LLM_PROVIDER=tongyi

# Embedding
VN_EMBEDDING_API_KEY=

# Transcribe (Bjian)
VN_BJIAN_APP_ID=
VN_BJIAN_ACCESS_TOKEN=

# HuggingFace 镜像（国内用户必须设置，否则模型下载会被墙）
# 海外用户可删除或注释掉这行
HF_ENDPOINT=https://hf-mirror.com

# Whisper
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto


# Bilibili Cookie（三选一）
#   browser — 从浏览器读取，首次成功后自动缓存（不稳定）
#   file    — 从 data/cookies.txt 读取，或用 scripts/save_cookie.py 生成
#   string  — 前端设置页粘贴，不留明文文件（生产推荐）
#   none    — 不使用 Cookie
VN_BILIBILI_COOKIE_SOURCE=browser
VN_BILIBILI_COOKIE_BROWSER=chrome
# VN_BILIBILI_COOKIE_FILE=data/cookies.txt
