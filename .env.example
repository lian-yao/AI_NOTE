# LLM API Keys
VN_TONGYI_API_KEY=
VN_DEEPSEEK_API_KEY=
VN_LLM_PROVIDER=tongyi

# Embedding
VN_EMBEDDING_API_KEY=

# Transcribe (Bjian)
VN_BJIAN_APP_ID=
VN_BJIAN_ACCESS_TOKEN=

# Whisper
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto

# Bilibili Cookie — 两种方式二选一：
# 方式一（推荐）：从浏览器导出 Netscape 格式 cookies.txt 放到 data/cookies.txt
#   yt-dlp --cookies-from-browser chrome --cookies data/cookies.txt
# 方式二：手动创建 data/cookies.txt，格式见 data/cookies.txt 示例
#   .bilibili.com  TRUE  /  TRUE  过期时间戳  SESSDATA  你的值
#   .bilibili.com  TRUE  /  TRUE  过期时间戳  sid       你的值
