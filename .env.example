# LLM API Keys
VN_TONGYI_API_KEY=
VN_DEEPSEEK_API_KEY=
VN_LLM_PROVIDER=tongyi

# LLM 模型选择（有默认值，不设置则用 qwen-plus / deepseek-chat）
# VN_TONGYI_MODEL=qwen-plus
# VN_DEEPSEEK_MODEL=deepseek-chat

# Embedding API Key（不设置则复用 VN_TONGYI_API_KEY）
VN_EMBEDDING_API_KEY=

# Vector DB 路径（默认 ./data/chromadb）
# VN_VECTOR_DB_PATH=./data/chromadb

# Transcribe（Bjian 服务，不设置则使用本地 Whisper）
VN_BJIAN_APP_ID=
VN_BJIAN_ACCESS_TOKEN=

# Whisper 模型配置
VN_WHISPER_MODEL_SIZE=tiny
VN_WHISPER_DEVICE=cpu

# Bilibili Cookie（默认 string，不自动读取浏览器 Cookie）
#   string  — 前端设置页粘贴，不留明文文件（推荐）
#   file    — 从 data/cookies.txt 读取，或用 scripts/save_cookie.py 生成
#   browser — 从浏览器读取，首次成功后自动缓存（可能受 DPAPI/浏览器锁库影响）
#   none    — 不使用 Cookie
VN_BILIBILI_COOKIE_SOURCE=string
VN_BILIBILI_COOKIE_BROWSER=chrome
# VN_BILIBILI_COOKIE_FILE=data/cookies.txt

# HuggingFace 镜像（国内用户建议设置，否则模型下载会被墙）
# 海外用户可删除或注释掉这行
HF_ENDPOINT=https://hf-mirror.com
